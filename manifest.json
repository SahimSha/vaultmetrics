{
  "manifest_version": 3,
  "name": "VaultMetrics Security",
  "version": "1.0.0",
  "description": "Advanced password auditing, heuristics, and Passkey generation.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open VaultMetrics"
  },
  "permissions": [
    "clipboardWrite",
    "storage"
  ],
  "icons": {
    "128": "icon.png"
  }
}